# Defining parameters for fluid properties
DEFINE L = 0
DEFINE RE_DELTA_STAR = 0
DEFINE MACH = 0
DEFINE U_INF = 0
DEFINE RHO_INF = 0
DEFINE T_INF = 0
DEFINE G = 0
DEFINE PR_LAM_VAL = 0
DEFINE MU_POWER_LAW_VAL = 0
DEFINE TRANSIENT_SIMTIME_VAL = 0
DEFINE CHECK_INTERVAL_VAL = 0
DEFINE CFL_VAL = 0
DEFINE WALL_BC = 0
DEFINE SGS_MODEL_VAL = 0
DEFINE TOTAL_DOMAIN_LENGTH = 0
DEFINE TIME_PROBES_WRITE_INTERVAL = 0

# Defining parameters for derived fluid properties
DEFINE P_INF = (1.0/($(G)*$(MACH)*$(MACH)))
DEFINE MU_INF = ($(RHO_INF)*$(U_INF)*1.0/$(RE_DELTA_STAR))

# Restart file (Mesh file)
RESTART ./helping_files/restart.mles

# Setting reference values (flow properties at inf)
PR_LAM = $(PR_LAM_VAL)
MU_POWER_LAW = $(MU_POWER_LAW_VAL)
RHO_REF = $(RHO_INF)
P_REF = $(P_INF)
T_REF = $(T_INF)
MU_REF = $(MU_INF)
GAMMA = $(G)
EOS = IDEAL_GAS

# Time advancement
TIMESTEP = CFL $(CFL_VAL)
SIMTIME = $(TRANSIENT_SIMTIME_VAL)
CHECK_INTERVAL = $(CHECK_INTERVAL_VAL)

# Initialization
INIT_RUP $(RHO_INF) 0 0 0 $(P_INF)

# Boundary conditions
INFLOW = CBC_RUP $(RHO_INF) $(U_INF) 0.0 0.0 $(P_INF)
OUTFLOW = NSCBC_OUTLET_PRESSURE P_REF $(P_INF) L_REF $(TOTAL_DOMAIN_LENGTH)
TOP = NSCBC_OUTLET_PRESSURE P_REF $(P_INF) L_REF $(TOTAL_DOMAIN_LENGTH)
RIGHT = SLIP
LEFT = SLIP
PREGAP_SLIP = SLIP
SOLIDS = $(WALL_BC)

# Wall modeling
SGS_MODEL = $(SGS_MODEL_VAL)

# Probes
