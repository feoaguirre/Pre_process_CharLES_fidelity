# Defining geometry parameters
DEFINE HALF_W = 0
DEFINE L = 0
DEFINE L1 = 0
DEFINE L2 = 0
DEFINE L3 = 0
DEFINE D = 0
DEFINE H = 0

# Creating the surfaces and giving them names (some names are temporary, necessary b/c of a bug in surfer)
SURF BOX -$(L2)-$(L1)   $(L)+$(L3)  0 $(H)  -$(HALF_W) $(HALF_W)

RENAME_ZONE INDEX 0 INFLOW
RENAME_ZONE INDEX 1 OUTFLOW
RENAME_ZONE INDEX 3 TOP
RENAME_ZONE INDEX 4 TEMP_LEFT
RENAME_ZONE INDEX 5 TEMP_RIGHT

IMPRINT ZONE_INDICES 2 PLANE -$(L2) 0 0 1 0 0 SPLIT_ZONES
IMPRINT ZONE_INDICES 6 PLANE 0 0 0 1 0 0 SPLIT_ZONES
IMPRINT ZONE_INDICES 7 PLANE $(L) 0 0 1 0 0 SPLIT_ZONES

RENAME_ZONE INDEX 2 PREGAP_SLIP
RENAME_ZONE INDEX 8 TEMP_POSTGAP
DELETE ZONE_INDICES 7
# Because of delete, temp_postgap now has index 7. Note that in general changing zones also moves around all the indices.

SURF BOX 0 $(L) -$(D) 0  -$(HALF_W) $(HALF_W)
DELETE ZONE_INDICES 11
MOVE_TO_ZONE NAME SOLIDS SUBZONES 6,7,8,9,10
MOVE_TO_ZONE NAME RIGHT SUBZONES 5,7
MOVE_TO_ZONE NAME LEFT SUBZONES 4,5

ZIP_OPEN_EDGES
#INTERACTIVE

WRITE_SBIN ./helping_files/geometry.sbin
